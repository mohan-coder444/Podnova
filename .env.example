# ──────────────────────────────────────────
# Podnova — Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ──────────────────────────────────────────

# InsForge Backend
INSFORGE_BASE_URL=https://py4cvy3v.us-east.insforge.app
INSFORGE_API_KEY=your_insforge_anon_key_here

# Mistral AI (script generation)
# Get key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# HuggingFace (script enhancement)
# Get key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here

# ElevenLabs (text-to-speech)
# Get key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ──────────────────────────────────────────
# Optional / Advanced
# ──────────────────────────────────────────

# App URL (used for absolute URLs in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default podcast options
NEXT_PUBLIC_DEFAULT_DURATION=5
NEXT_PUBLIC_DEFAULT_STYLE=conversational
